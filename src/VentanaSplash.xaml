<Window x:Class="Malyzer.VentanaSplash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="460" Height="320"
        ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="14" BorderBrush="{StaticResource ColorAcento}" BorderThickness="1">
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Color="#1A0A0A" Offset="0"/>
                <GradientStop Color="#080404" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#E11D2E" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Source="/Recursos/logo_256.png" Width="140" Height="140" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,32,0,0">
                <Image.Effect>
                    <DropShadowEffect Color="#E11D2E" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
                </Image.Effect>
            </Image>
            <TextBlock Grid.Row="1" Text="MALYZER" Foreground="{StaticResource ColorAcento}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#E11D2E" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Grid.Row="2" Text="MALWARE ANALYZER" Foreground="{StaticResource ColorTextoTenue}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            <Grid Grid.Row="3" Margin="40,16,40,28">
                <ProgressBar IsIndeterminate="True" Height="3" Background="{StaticResource ColorSuperficie}" Foreground="{StaticResource ColorAcento}"/>
                <TextBlock x:Name="textoEstado" Text="Iniciando..." HorizontalAlignment="Center" Foreground="{StaticResource ColorTextoSecundario}" FontSize="11" Margin="0,12,0,0" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
    </Border>
</Window>
