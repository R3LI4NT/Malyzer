<Page x:Class="Malyzer.Vistas.PaginaAnalisisDinamico"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.dinamico.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.dinamico.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Ejecutable:" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="campoEjecutable" Width="500" IsReadOnly="True"/>
                        <Button Content="Examinar" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="Examinar_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="botonEjecutar" Content="Ejecutar" Style="{StaticResource BotonPrimario}" Click="Ejecutar_Click" IsEnabled="False" Margin="0,0,8,0"/>
                        <Button x:Name="botonDetener" Content="{loc:Loc btn.detener}" Style="{StaticResource BotonPeligro}" Click="Detener_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Timeout (s):" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" x:Name="campoTimeout" Text="60" Width="60" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Capturar red" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="20,0,8,0"/>
                    <CheckBox Grid.Column="3" x:Name="chkRed" IsChecked="True" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Vigilar:" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="20,0,8,0"/>
                    <TextBox Grid.Column="5" x:Name="campoDirectorios" Text="%TEMP%; %APPDATA%; C:\Windows\System32" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="textoEstadoDinamico" Text="Detenido" Foreground="{StaticResource ColorTextoSecundario}"/>
                    <ProgressBar x:Name="barraDinamica" Height="4" Margin="0,8,0,0" IsIndeterminate="False"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="{StaticResource ColorSuperficie1}" CornerRadius="4" Padding="8,4" Margin="4,0,0,0">
                        <TextBlock x:Name="contProcesos" Text="P:0" Foreground="{StaticResource ColorAcento}"/>
                    </Border>
                    <Border Background="{StaticResource ColorSuperficie1}" CornerRadius="4" Padding="8,4" Margin="4,0,0,0">
                        <TextBlock x:Name="contArchivos" Text="A:0" Foreground="{StaticResource ColorVerde}"/>
                    </Border>
                    <Border Background="{StaticResource ColorSuperficie1}" CornerRadius="4" Padding="8,4" Margin="4,0,0,0">
                        <TextBlock x:Name="contRegistro" Text="R:0" Foreground="{StaticResource ColorAmarillo}"/>
                    </Border>
                    <Border Background="{StaticResource ColorSuperficie1}" CornerRadius="4" Padding="8,4" Margin="4,0,0,0">
                        <TextBlock x:Name="contRed" Text="N:0" Foreground="{StaticResource ColorMorado}"/>
                    </Border>
                    <Border Background="{StaticResource ColorSuperficie1}" CornerRadius="4" Padding="8,4" Margin="4,0,0,0">
                        <TextBlock x:Name="contAlertas" Text="!:0" Foreground="{StaticResource ColorRojo}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="3">
            <TabItem Header="Procesos">
                <DataGrid x:Name="gridProcesos" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hora" Binding="{Binding Hora}" Width="100"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="80"/>
                        <DataGridTextColumn Header="Padre" Binding="{Binding PidPadre}" Width="80"/>
                        <DataGridTextColumn Header="{loc:Loc col.nombre}" Binding="{Binding Nombre}" Width="200"/>
                        <DataGridTextColumn Header="{loc:Loc col.accion}" Binding="{Binding Accion}" Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc col.linea_comando}" Binding="{Binding LineaComando}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Archivos">
                <DataGrid x:Name="gridArchivos" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hora" Binding="{Binding Hora}" Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc col.operacion}" Binding="{Binding Operacion}" Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc col.tamano}" Binding="{Binding Tamano}" Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc lbl.ruta}" Binding="{Binding Ruta}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Registro">
                <DataGrid x:Name="gridRegistro" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hora" Binding="{Binding Hora}" Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc col.operacion}" Binding="{Binding Operacion}" Width="100"/>
                        <DataGridTextColumn Header="Clave" Binding="{Binding Clave}" Width="*"/>
                        <DataGridTextColumn Header="Valor" Binding="{Binding Valor}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Red">
                <DataGrid x:Name="gridRed" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hora" Binding="{Binding Hora}" Width="100"/>
                        <DataGridTextColumn Header="Protocolo" Binding="{Binding Protocolo}" Width="80"/>
                        <DataGridTextColumn Header="Origen" Binding="{Binding Origen}" Width="180"/>
                        <DataGridTextColumn Header="Destino" Binding="{Binding Destino}" Width="180"/>
                        <DataGridTextColumn Header="Puerto" Binding="{Binding Puerto}" Width="80"/>
                        <DataGridTextColumn Header="{loc:Loc col.direccion}" Binding="{Binding Direccion}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Alertas">
                <ListBox x:Name="listaAlertas" Background="{StaticResource ColorMantle}" FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
