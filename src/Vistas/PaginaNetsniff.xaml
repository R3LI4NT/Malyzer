<Page x:Class="Malyzer.Vistas.PaginaNetsniff"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.netsniff.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.netsniff.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="{loc:Loc pag.netsniff.tab_captura}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc pag.netsniff.adaptador}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" x:Name="comboAdaptador"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Content="{loc:Loc btn.recargar}" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="RecargarAdaptadores_Click"/>
                                <Button x:Name="botonIniciar" Content="{loc:Loc pag.netsniff.iniciar}" Style="{StaticResource BotonPrimario}" Margin="0,0,8,0" Click="Iniciar_Click"/>
                                <Button x:Name="botonDetener" Content="{loc:Loc btn.detener}" Style="{StaticResource BotonPeligro}" Margin="0,0,8,0" IsEnabled="False" Click="Detener_Click"/>
                                <Button Content="{loc:Loc pag.netsniff.exportar_pcap}" Style="{StaticResource BotonSecundario}" Click="ExportarPcap_Click"/>
                                <Button Content="{loc:Loc btn.exportar_pdf}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="ExportarPdf_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Paquetes" Foreground="{StaticResource ColorTextoSecundario}" FontSize="11"/>
                                <TextBlock x:Name="kpiPaquetes" Text="0" Foreground="{StaticResource ColorAcento}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Bytes totales" Foreground="{StaticResource ColorTextoSecundario}" FontSize="11"/>
                                <TextBlock x:Name="kpiBytes" Text="0 B" Foreground="{StaticResource ColorRosa}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Loc pag.netsniff.kpi.hosts}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="11"/>
                                <TextBlock x:Name="kpiHosts" Text="0" Foreground="{StaticResource ColorTeal}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="{loc:Loc pag.netsniff.kpi.trafico}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="11"/>
                                <TextBlock x:Name="kpiTrafico" Text="0 B/s" Foreground="{StaticResource ColorAmarillo}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{loc:Loc pag.netsniff.kpi.duracion}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="11"/>
                                <TextBlock x:Name="kpiDuracion" Text="00:00:00" Foreground="{StaticResource ColorVerde}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2" x:Name="gridPaquetes" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{loc:Loc pag.netsniff.menu_geoip}" Click="InspeccionarIp_Click"/>
                                <MenuItem Header="{loc:Loc pag.netsniff.menu_copiar_ip}" Click="CopiarIpRemota_Click"/>
                                <Separator/>
                                <MenuItem Header="{loc:Loc pag.netsniff.menu_virustotal}" Click="VirustotalIp_Click"/>
                                <MenuItem Header="{loc:Loc pag.netsniff.menu_abuseipdb}" Click="AbuseIpDb_Click"/>
                                <MenuItem Header="{loc:Loc pag.netsniff.menu_shodan}" Click="Shodan_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hora" Binding="{Binding FechaTexto}" Width="80"/>
                            <DataGridTextColumn Header="Proto" Binding="{Binding Protocolo}" Width="60"/>
                            <DataGridTextColumn Header="Local" Binding="{Binding IpLocal}" Width="140"/>
                            <DataGridTextColumn Header="P.Loc" Binding="{Binding PuertoLocal}" Width="60"/>
                            <DataGridTextColumn Header="Remoto" Binding="{Binding IpRemota}" Width="140"/>
                            <DataGridTextColumn Header="P.Rem" Binding="{Binding PuertoRemoto}" Width="60"/>
                            <DataGridTextColumn Header="Servicio" Binding="{Binding Servicio}" Width="120"/>
                            <DataGridTextColumn Header="{loc:Loc col.proceso}" Binding="{Binding Proceso}" Width="160"/>
                            <DataGridTextColumn Header="Bytes" Binding="{Binding Tamano}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.netsniff.tab_filtros}">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Filtros activos" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,12"/>
                            <CheckBox x:Name="chkSoloTcp" Content="Solo TCP" Margin="0,4"/>
                            <CheckBox x:Name="chkSoloUdp" Content="Solo UDP" Margin="0,4"/>
                            <CheckBox x:Name="chkSinLocales" Content="{loc:Loc pag.netsniff.ocultar_local}" Margin="0,4"/>
                            <Grid Margin="0,12,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Host contiene:" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="campoHost"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rango puerto:" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="campoPuertoMin"/>
                                <TextBlock Grid.Column="2" Text=" — " VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="3" x:Name="campoPuertoMax"/>
                            </Grid>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="BPF (avanzado):" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="campoBpf" ToolTip="Sintaxis libpcap, ej: 'tcp port 443 or udp port 53'"/>
                            </Grid>
                            <Button Content="{loc:Loc btn.aplicar_filtros}" Style="{StaticResource BotonPrimario}" HorizontalAlignment="Left" Margin="0,16,0,0" Click="AplicarFiltros_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource EstiloTarjeta}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.netsniff.lista_negra}" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,8"/>
                            <TextBlock Text="{loc:Loc pag.netsniff.lista_negra_help}" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBox x:Name="campoBlacklist" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="120" FontFamily="Cascadia Mono"/>
                            <Button Content="{loc:Loc btn.aplicar_blacklist}" Style="{StaticResource BotonSecundario}" HorizontalAlignment="Left" Margin="0,8,0,0" Click="AplicarBlacklist_Click"/>

                            <TextBlock Text="Notificaciones" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,20,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="notifHost" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="1" x:Name="notifPuerto" Margin="4,0"/>
                                <ComboBox Grid.Column="2" x:Name="notifProto" Margin="4,0,0,0">
                                    <ComboBoxItem Content="" IsSelected="True"/>
                                    <ComboBoxItem Content="TCP"/>
                                    <ComboBoxItem Content="UDP"/>
                                </ComboBox>
                                <Button Grid.Column="3" Content="+" Style="{StaticResource BotonPrimario}" Margin="4,0,0,0" Click="AgregarNotif_Click"/>
                            </Grid>
                            <ItemsControl x:Name="listaNotif" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.netsniff.tab_estadisticas}">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.netsniff.por_protocolo}" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="listaProtos">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Nombre}" Foreground="{StaticResource ColorTexto}" FontFamily="Cascadia Mono"/>
                                            <Border Grid.Column="1" Background="{StaticResource ColorSuperficie1}" CornerRadius="2" Height="14">
                                                <Border Background="{StaticResource ColorAcento}" CornerRadius="2" HorizontalAlignment="Left" Width="{Binding Ancho}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Conteo}" Foreground="{StaticResource ColorTextoSecundario}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource EstiloTarjeta}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.netsniff.trafico_60}" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,12"/>
                            <Canvas x:Name="canvasGrafico" Height="240" Background="{StaticResource ColorMantle}"/>
                            <TextBlock x:Name="textoMaxTrafico" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.netsniff.tab_alertas}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="resumenAlertas" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,0,0,8" Text="{loc:Loc pag.netsniff.sin_alertas}"/>
                    <DataGrid Grid.Row="1" x:Name="gridAlertas" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hora" Binding="{Binding CuandoTexto}" Width="100"/>
                            <DataGridTextColumn Header="{loc:Loc col.tipo}" Binding="{Binding Tipo}" Width="120"/>
                            <DataGridTextColumn Header="Severidad" Binding="{Binding Severidad}" Width="100"/>
                            <DataGridTextColumn Header="Mensaje" Binding="{Binding Mensaje}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
