<Page x:Class="Malyzer.Vistas.PaginaInteligencia"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.intel.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.intel.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="comboTipo" Margin="0,0,8,0">
                        <ComboBoxItem Content="{loc:Loc lbl.auto_detectar}" IsSelected="True"/>
                        <ComboBoxItem Content="hash"/>
                        <ComboBoxItem Content="ip"/>
                        <ComboBoxItem Content="dominio"/>
                        <ComboBoxItem Content="url"/>
                    </ComboBox>
                    <TextBox Grid.Column="1" x:Name="campoIoc" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                        <Button x:Name="botonConsultar" Content="{loc:Loc btn.consultar}" Style="{StaticResource BotonPrimario}" Click="Consultar_Click"/>
                        <Button Content="{loc:Loc btn.limpiar}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="Limpiar_Click"/>
                    </StackPanel>
                </Grid>
                <TextBlock Grid.Row="1" Text="{loc:Loc pag.intel.iocs_help}" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12" Visibility="Collapsed" x:Name="cajaResumen">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc pag.intel.puntuacion_global}" Foreground="{StaticResource ColorTextoSecundario}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" x:Name="barraGlobal" Height="14" Margin="12,0" Value="0" Maximum="100"/>
                <TextBlock Grid.Column="2" x:Name="textoGlobal" Text="0/100" FontWeight="Bold" Foreground="{StaticResource ColorTexto}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ListBox Grid.Row="3" x:Name="listaResultados" Background="{StaticResource ColorBase}" BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource ColorSuperficie}" CornerRadius="6" Padding="14,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{Binding ColorTipo}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Tipo}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource ColorBase}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Valor}" FontFamily="Cascadia Mono" Foreground="{StaticResource ColorTexto}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Detalles}" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding FuenteFecha}" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                <TextBlock Text="{Binding Reputacion}" FontSize="22" FontWeight="Bold" Foreground="{Binding ColorReputacion}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc pag.intel.reputacion}" FontSize="10" Foreground="{StaticResource ColorTextoTenue}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
