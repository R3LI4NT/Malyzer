<Page x:Class="Malyzer.Vistas.PaginaInteligencia"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.intel.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.intel.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="{loc:Loc pag.intel.tab_lookup}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" x:Name="comboTipo" Margin="0,0,8,0">
                                    <ComboBoxItem Content="{loc:Loc lbl.auto_detectar}" IsSelected="True"/>
                                    <ComboBoxItem Content="hash"/>
                                    <ComboBoxItem Content="ip"/>
                                    <ComboBoxItem Content="dominio"/>
                                    <ComboBoxItem Content="url"/>
                                </ComboBox>
                                <TextBox Grid.Column="1" x:Name="campoIoc" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                    <Button x:Name="botonConsultar" Content="{loc:Loc btn.consultar}" Style="{StaticResource BotonPrimario}" Click="Consultar_Click"/>
                                    <Button Content="{loc:Loc btn.limpiar}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="Limpiar_Click"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox x:Name="chkUsarMb" Content="{loc:Loc pag.intel.usar_mb}" Foreground="{StaticResource ColorTexto}" Margin="0,0,16,0" IsChecked="True"/>
                                <CheckBox x:Name="chkUsarTf" Content="{loc:Loc pag.intel.usar_tf}" Foreground="{StaticResource ColorTexto}" IsChecked="True"/>
                                <Button Content="{loc:Loc btn.exportar_pdf}" Style="{StaticResource BotonSecundario}" Margin="32,0,0,0" Click="ExportarPdf_Click"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{loc:Loc pag.intel.iocs_help}" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12" Visibility="Collapsed" x:Name="cajaResumen">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc pag.intel.puntuacion_global}" Foreground="{StaticResource ColorTextoSecundario}" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="barraGlobal" Height="14" Margin="12,0" Value="0" Maximum="100"/>
                            <TextBlock Grid.Column="2" x:Name="textoGlobal" Text="0/100" FontWeight="Bold" Foreground="{StaticResource ColorTexto}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="3" x:Name="listaResultados" Background="{StaticResource ColorBase}" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ColorSuperficie}" CornerRadius="6" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{Binding ColorTipo, Mode=OneWay}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Tipo, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource ColorBase}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Valor, Mode=OneWay}" FontFamily="Cascadia Mono" Foreground="{StaticResource ColorTexto}" FontSize="13"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Detalles, Mode=OneWay}" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding FuenteFecha, Mode=OneWay}" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                            <TextBlock Text="{Binding Reputacion, Mode=OneWay}" FontSize="22" FontWeight="Bold" Foreground="{Binding ColorReputacion, Mode=OneWay}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{loc:Loc pag.intel.reputacion}" FontSize="10" Foreground="{StaticResource ColorTextoTenue}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.intel.tab_upload}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12" BorderBrush="{StaticResource ColorAcento}" BorderThickness="0,0,0,2">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc pag.intel.upload_titulo}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,8"/>
                                <TextBlock Text="{loc:Loc pag.intel.upload_aviso}" Foreground="{StaticResource ColorTextoSecundario}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc pag.intel.upload_archivo}" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource ColorTexto}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="campoArchivoSubir" IsReadOnly="True"/>
                                    <Button Grid.Column="1" Content="{loc:Loc btn.examinar}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="ExaminarArchivoSubir_Click"/>
                                </Grid>
                                <TextBlock x:Name="textoInfoArchivo" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc pag.intel.upload_destino}" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource ColorTexto}"/>
                                <CheckBox x:Name="chkSubirVt" Content="{loc:Loc pag.intel.upload_vt}" Foreground="{StaticResource ColorTexto}" Margin="0,4" IsChecked="True"/>
                                <CheckBox x:Name="chkSubirMb" Content="{loc:Loc pag.intel.upload_mb}" Foreground="{StaticResource ColorTexto}" Margin="0,4"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc pag.intel.upload_meta}" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource ColorTexto}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc pag.intel.upload_etiquetas}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,4"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="campoEtiquetas" Margin="0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc pag.intel.upload_comentario}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Top" Margin="0,8"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="campoComentario" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,8"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkPublico" Content="{loc:Loc pag.intel.upload_publico}" Foreground="{StaticResource ColorTexto}" Margin="0,4" IsChecked="True"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button x:Name="botonSubir" Content="{loc:Loc btn.subir}" Style="{StaticResource BotonPrimario}" Click="Subir_Click"/>
                            <Button x:Name="botonCancelarSubida" Content="{loc:Loc btn.cancelar}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="CancelarSubida_Click" IsEnabled="False"/>
                            <Button Content="{loc:Loc btn.exportar_pdf}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="ExportarPdfSubidas_Click"/>
                        </StackPanel>

                        <Border Grid.Row="5" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12" Visibility="Collapsed" x:Name="cajaProgreso">
                            <StackPanel>
                                <TextBlock x:Name="textoProgreso" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,6"/>
                                <ProgressBar x:Name="barraProgreso" IsIndeterminate="True" Height="6"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl Grid.Row="6" x:Name="listaSubidas" Background="Transparent">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ColorSuperficie}" CornerRadius="6" Padding="14,12" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{Binding ColorEstado, Mode=OneWay}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Servicio, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource ColorBase}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Estado, Mode=OneWay}" Foreground="{StaticResource ColorTexto}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Mensaje, Mode=OneWay}" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding HashSha256, Mode=OneWay}" FontFamily="Cascadia Mono" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" Margin="0,4,0,0"/>
                                                <TextBlock Margin="0,4,0,0" Visibility="{Binding TieneUrl, Mode=OneWay}">
                                                    <Hyperlink NavigateUri="{Binding UrlReporteUri, Mode=OneWay}" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{StaticResource ColorAcento}">
                                                        <Run Text="{Binding UrlReporte, Mode=OneWay}"/>
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="12,0,0,0">
                                                <Button x:Name="botonVerSubida" ToolTip="Visualizar resultados por motor antivirus"
                                                        Click="VerSubida_Click" Tag="{Binding Id, Mode=OneWay}"
                                                        Width="34" Height="34" Margin="0,0,4,0"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource ColorBorde}"
                                                        Foreground="{StaticResource ColorTexto}" Cursor="Hand"
                                                        Visibility="{Binding VerVisible, Mode=OneWay}">
                                                    <Path Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"
                                                          Fill="{StaticResource ColorAcento}" Stretch="Uniform" Width="18" Height="18"/>
                                                </Button>
                                                <Button x:Name="botonEliminarSubida" ToolTip="Eliminar esta entrada de la lista"
                                                        Click="EliminarSubida_Click" Tag="{Binding Id, Mode=OneWay}"
                                                        Width="34" Height="34"
                                                        Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource ColorBorde}"
                                                        Foreground="{StaticResource ColorTexto}" Cursor="Hand">
                                                    <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z"
                                                          Fill="{StaticResource ColorRojoBrillante}" Stretch="Uniform" Width="18" Height="18"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
