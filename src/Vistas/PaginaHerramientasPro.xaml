<Page x:Class="Malyzer.Vistas.PaginaHerramientasPro"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.pro.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.pro.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="{loc:Loc pag.pro.tab_dump}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource ColorRojo}" CornerRadius="4" Padding="12,8" Margin="0,0,0,12" Opacity="0.8">
                        <TextBlock Foreground="{StaticResource ColorBase}" FontWeight="SemiBold" TextWrapping="Wrap" Text="{loc:Loc pag.pro.advertencia_volcado}"/>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PID:" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="campoPid" Width="120" HorizontalAlignment="Left"/>
                        <Button Grid.Column="2" Content="{loc:Loc btn.listar_procesos}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="ListarProcesos_Click"/>
                        <Button Grid.Column="3" Content="{loc:Loc btn.volcar_memoria}" Style="{StaticResource BotonPrimario}" Margin="8,0,0,0" Click="Volcar_Click"/>
                    </Grid>
                    <TextBlock Grid.Row="2" x:Name="textoVolcado" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,0,0,12"/>
                    <DataGrid Grid.Row="3" x:Name="gridProcesosSistema" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="100"/>
                            <DataGridTextColumn Header="{loc:Loc col.nombre}" Binding="{Binding Nombre}" Width="280"/>
                            <DataGridTextColumn Header="{loc:Loc col.memoria}" Binding="{Binding Memoria}" Width="120"/>
                            <DataGridTextColumn Header="Inicio" Binding="{Binding Inicio}" Width="180"/>
                            <DataGridTextColumn Header="{loc:Loc lbl.ruta}" Binding="{Binding Ruta}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.pro.tab_deobfusc}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="campoArchivoDeo" IsReadOnly="True" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="Examinar" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="ExaminarDeo_Click"/>
                            <Button Content="Probar combinaciones" Style="{StaticResource BotonPrimario}" Click="ProbarDeo_Click"/>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Base64" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,6"/>
                                <TextBox x:Name="campoB64In" AcceptsReturn="True" Height="50" Margin="0,0,0,4"/>
                                <Button Content="Decodificar" Style="{StaticResource BotonSecundario}" Click="B64_Click"/>
                                <TextBox x:Name="campoB64Out" IsReadOnly="True" Height="60" AcceptsReturn="True" Margin="0,4,0,0" Background="{StaticResource ColorMantle}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource EstiloTarjeta}" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Hex" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,6"/>
                                <TextBox x:Name="campoHexIn" AcceptsReturn="True" Height="50" Margin="0,0,0,4"/>
                                <Button Content="Decodificar" Style="{StaticResource BotonSecundario}" Click="Hex_Click"/>
                                <TextBox x:Name="campoHexOut" IsReadOnly="True" Height="60" AcceptsReturn="True" Margin="0,4,0,0" Background="{StaticResource ColorMantle}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource EstiloTarjeta}" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="URL" FontWeight="SemiBold" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,6"/>
                                <TextBox x:Name="campoUrlIn" AcceptsReturn="True" Height="50" Margin="0,0,0,4"/>
                                <Button Content="Decodificar" Style="{StaticResource BotonSecundario}" Click="Url_Click"/>
                                <TextBox x:Name="campoUrlOut" IsReadOnly="True" Height="60" AcceptsReturn="True" Margin="0,4,0,0" Background="{StaticResource ColorMantle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <DataGrid Grid.Row="2" x:Name="gridResultadosDeo" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc pag.pro.tecnica}" Binding="{Binding Tecnica}" Width="140"/>
                            <DataGridTextColumn Header="Clave" Binding="{Binding Clave}" Width="120"/>
                            <DataGridTextColumn Header="{loc:Loc pag.pro.puntuacion}" Binding="{Binding PuntuacionTexto}" Width="100"/>
                            <DataGridTextColumn Header="Resultado (preview)" Binding="{Binding Resultado}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.pro.tab_extract}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="campoArchivoCfg" IsReadOnly="True" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="Examinar" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="ExaminarCfg_Click"/>
                            <Button Content="Extraer config" Style="{StaticResource BotonPrimario}" Click="ExtraerCfg_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="1" x:Name="textoEstadoCfg" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="contenedorCfg"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="{loc:Loc pag.pro.tab_emulation}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{loc:Loc pag.pro.bytes_help}" Foreground="{StaticResource ColorTextoSecundario}" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="campoBytesEm" Height="80" AcceptsReturn="True" FontFamily="Cascadia Mono" Text="55 8B EC 83 EC 10 90 C9 C3"/>
                        <Button Grid.Column="1" Content="Emular" Style="{StaticResource BotonPrimario}" Margin="8,0,0,0" VerticalAlignment="Top" Click="Emular_Click"/>
                    </Grid>
                    <TextBox Grid.Row="2" x:Name="campoSalidaEm" IsReadOnly="True" AcceptsReturn="True" FontFamily="Cascadia Mono" FontSize="12" Background="{StaticResource ColorMantle}" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
