<Page x:Class="Malyzer.Vistas.PaginaInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="32,24,32,32">
            <StackPanel>
                <Border CornerRadius="12" Margin="0,0,0,20" Padding="28,20" BorderBrush="{StaticResource ColorAcento}" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1A0808" Offset="0"/>
                            <GradientStop Color="#2A0F0F" Offset="0.5"/>
                            <GradientStop Color="#1A0808" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="/Recursos/logo_256.png" Width="84" Height="84" Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect Color="#E11D2E" BlurRadius="24" ShadowDepth="0" Opacity="0.8"/>
                            </Image.Effect>
                        </Image>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="MALYZER" Foreground="{StaticResource ColorAcento}" FontSize="28" FontWeight="Bold">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#E11D2E" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{loc:Loc pag.inicio.subtitulo}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="13" Margin="0,2,0,0"/>
                            <TextBlock x:Name="textoEstadoLab" Text="{loc:Loc pag.inicio.lab_operativo}" Foreground="{StaticResource ColorVerde}" FontSize="11" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button x:Name="botonImportarHero" Content="{loc:Loc pag.inicio.importar_muestras}" Style="{StaticResource BotonPrimario}" Click="ImportarRapido_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Columns="4" Rows="1" Margin="0,0,0,16">
                    <Border Style="{StaticResource EstiloTarjeta}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.inicio.muestras_totales}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="12"/>
                            <TextBlock x:Name="contadorMuestras" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorAcento}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource EstiloTarjeta}" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.inicio.riesgo_alto}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="12"/>
                            <TextBlock x:Name="contadorRiesgoAlto" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorRojoBrillante}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource EstiloTarjeta}" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.inicio.familias}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="12"/>
                            <TextBlock x:Name="contadorFamilias" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorRosa}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource EstiloTarjeta}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.inicio.pendientes}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="12"/>
                            <TextBlock x:Name="contadorPendientes" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorAmarillo}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.inicio.distribucion}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="listaFamilias">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Familia}" Foreground="{StaticResource ColorTextoSecundario}"/>
                                            <Border Grid.Column="1" Background="{StaticResource ColorSuperficie1}" CornerRadius="2" Height="14" HorizontalAlignment="Stretch">
                                                <Border Background="{StaticResource ColorAcento}" CornerRadius="2" HorizontalAlignment="Left" Width="{Binding AnchoBarra}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Cantidad}" HorizontalAlignment="Right" Foreground="{StaticResource ColorTexto}" FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="textoVacioFamilias" Text="{loc:Loc pag.inicio.sin_muestras}" Foreground="{StaticResource ColorTextoTenue}" FontStyle="Italic" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource EstiloTarjeta}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc pag.inicio.recientes}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="listaUltimas">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource ColorSuperficie}" CornerRadius="6" Padding="12,8" Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding NombreOriginal}" Foreground="{StaticResource ColorTexto}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding HashCorto}" Foreground="{StaticResource ColorTextoTenue}" FontSize="11" FontFamily="Cascadia Mono"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{Binding ColorRiesgo}" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TextoRiesgo}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ColorBase}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="textoVacioUltimas" Text="Sin muestras recientes." Foreground="{StaticResource ColorTextoTenue}" FontStyle="Italic" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource EstiloTarjeta}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc pag.inicio.acciones}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{loc:Loc pag.inicio.importar_muestra}" Style="{StaticResource BotonPrimario}" Margin="0,0,8,0" Click="ImportarRapido_Click"/>
                            <Button Content="{loc:Loc nav.estatico}" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="IrEstatico_Click"/>
                            <Button Content="{loc:Loc nav.dinamico}" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="IrDinamico_Click"/>
                            <Button Content="{loc:Loc nav.config}" Style="{StaticResource BotonSecundario}" Click="IrConfig_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource EstiloTarjeta}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc pag.inicio.entorno}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,12"/>
                        <StackPanel x:Name="listaEstado"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
