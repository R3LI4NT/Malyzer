<Page x:Class="Malyzer.Vistas.PaginaClasificacion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.ml.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.ml.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc lbl.archivo}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="campoRuta" Width="500" IsReadOnly="True"/>
                    <TextBlock x:Name="textoEntrenamiento" Foreground="{StaticResource ColorTextoTenue}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{loc:Loc btn.seleccionar}" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="Seleccionar_Click"/>
                    <Button x:Name="botonClasificar" Content="{loc:Loc btn.clasificar}" Style="{StaticResource BotonPrimario}" Margin="0,0,8,0" Click="Clasificar_Click" IsEnabled="False"/>
                    <Button Content="{loc:Loc btn.agrupar_repo}" Style="{StaticResource BotonSecundario}" Click="AgruparRepo_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc pag.ml.caract_extraidas}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,12"/>
                        <Grid x:Name="gridCaracteristicas">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                        <TextBlock x:Name="textoVacioCar" Text="{loc:Loc pag.ml.sin_datos}" Foreground="{StaticResource ColorTextoTenue}" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource EstiloTarjeta}" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Resultado" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource ColorAcento}" Margin="0,0,0,12"/>

                        <Grid x:Name="bloqueResultado" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource ColorSuperficie1}" CornerRadius="6" Padding="14,12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc pag.ml.familia_predicha}" Foreground="{StaticResource ColorTextoSecundario}" FontSize="12"/>
                                    <TextBlock x:Name="textoEtiqueta" Text="-" FontSize="22" FontWeight="Bold" Foreground="{StaticResource ColorRosa}" Margin="0,4,0,0"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Confianza" Foreground="{StaticResource ColorTextoSecundario}" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" x:Name="barraConfianza" Height="10" Margin="12,0" Maximum="100"/>
                                        <TextBlock Grid.Column="2" x:Name="textoConfianza" Foreground="{StaticResource ColorTexto}" FontWeight="SemiBold"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Row="1" Text="{loc:Loc pag.ml.distribucion_probs}" FontWeight="SemiBold" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,8"/>
                            <ItemsControl Grid.Row="2" x:Name="listaDistribucion" Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Etiqueta}" Foreground="{StaticResource ColorTexto}"/>
                                            <Border Grid.Column="1" Background="{StaticResource ColorSuperficie1}" CornerRadius="2" Height="12">
                                                <Border Background="{StaticResource ColorAcento}" CornerRadius="2" HorizontalAlignment="Left" Width="{Binding Ancho}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Porcentaje}" Foreground="{StaticResource ColorTextoSecundario}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Grid.Row="3" Text="{loc:Loc pag.ml.vecinos}" FontWeight="SemiBold" Foreground="{StaticResource ColorTexto}" Margin="0,0,0,8"/>
                            <ItemsControl Grid.Row="4" x:Name="listaVecinos">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource ColorSuperficie}" CornerRadius="4" Padding="10,6" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Etiqueta}" Foreground="{StaticResource ColorTexto}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Distancia}" Foreground="{StaticResource ColorTextoTenue}" FontFamily="Cascadia Mono"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <TextBlock x:Name="textoVacioRes" Text="{loc:Loc pag.ml.sin_clasificacion}" Foreground="{StaticResource ColorTextoTenue}" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
