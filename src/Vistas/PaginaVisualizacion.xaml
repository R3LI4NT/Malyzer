<Page x:Class="Malyzer.Vistas.PaginaVisualizacion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.visual.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.visual.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc pag.visual.archivo}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="campoRuta" IsReadOnly="True" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="{loc:Loc btn.examinar}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="Examinar_Click"/>
                <Button Grid.Column="3" Content="{loc:Loc pag.visual.de_repo}" Style="{StaticResource BotonSecundario}" Margin="8,0,0,0" Click="DeRepo_Click"/>
                <Button Grid.Column="4" x:Name="botonAnalizar" Content="{loc:Loc pag.visual.analizar_visualizar}" Style="{StaticResource BotonPrimario}" Margin="8,0,0,0" Click="Analizar_Click" IsEnabled="False"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc pag.visual.modo}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="comboTipo" Width="240" SelectionChanged="Tipo_Changed">
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.entropia}" IsSelected="True"/>
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.imports}"/>
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.iocs}"/>
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.histograma}"/>
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.strings}"/>
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.layout}"/>
                        <ComboBoxItem Content="{loc:Loc pag.visual.modo.arbol}"/>
                    </ComboBox>
                    <TextBlock x:Name="textoMuestra" Foreground="{StaticResource ColorTextoTenue}" VerticalAlignment="Center" Margin="20,0,0,0" Text="{loc:Loc lbl.sin_archivo}"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Background="{StaticResource ColorMantle}" CornerRadius="8" BorderBrush="{StaticResource ColorBorde}" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="lienzo" Width="1100" Height="650" Background="Transparent"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
