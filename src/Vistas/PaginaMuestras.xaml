<Page x:Class="Malyzer.Vistas.PaginaMuestras"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Malyzer"
      Background="{StaticResource ColorBase}"
      Foreground="{StaticResource ColorTexto}">
    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Loc pag.muestras.titulo}" Style="{StaticResource TituloPagina}"/>
            <TextBlock Text="{loc:Loc pag.muestras.subtitulo}" Style="{StaticResource SubtituloPagina}" Margin="0,0,0,16"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource EstiloTarjeta}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc pag.muestras.buscar}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="campoBusqueda" Width="280" TextChanged="Busqueda_Changed"/>
                    <TextBlock Text="{loc:Loc pag.muestras.familia}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox x:Name="comboFamilia" Width="180" SelectionChanged="Filtros_Changed"/>
                    <TextBlock Text="{loc:Loc pag.muestras.riesgo_min}" Style="{StaticResource EtiquetaCampo}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox x:Name="comboRiesgo" Width="120" SelectionChanged="Filtros_Changed">
                        <ComboBoxItem Content="(cualquiera)" IsSelected="True"/>
                        <ComboBoxItem Content="20+ bajo"/>
                        <ComboBoxItem Content="40+ medio"/>
                        <ComboBoxItem Content="60+ alto"/>
                        <ComboBoxItem Content="{loc:Loc pag.muestras.riesgo_critico}"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{loc:Loc btn.importar}" Style="{StaticResource BotonPrimario}" Margin="0,0,8,0" Click="Importar_Click"/>
                    <Button Content="{loc:Loc btn.exportar_pdf}" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="ExportarPdf_Click"/>
                    <Button Content="{loc:Loc btn.refrescar}" Style="{StaticResource BotonSecundario}" Click="Refrescar_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" x:Name="gridMuestras" AutoGenerateColumns="False" SelectionChanged="Muestra_SelectionChanged" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc col.nombre}" Binding="{Binding NombreOriginal}" Width="220" IsReadOnly="True"/>
                <DataGridTextColumn Header="SHA-256" Binding="{Binding HashCorto}" Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="{loc:Loc col.tamano}" Binding="{Binding TamanoTexto}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="{loc:Loc col.tipo}" Binding="{Binding TipoArchivo}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="{loc:Loc col.familia}" Binding="{Binding Familia, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Etiquetas" Binding="{Binding Etiquetas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                <DataGridTextColumn Header="{loc:Loc col.riesgo}" Binding="{Binding PuntuacionRiesgo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="{loc:Loc col.estado}" Binding="{Binding EstadoAnalisis}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ingreso" Binding="{Binding FechaIngresoTexto}" Width="140" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Style="{StaticResource EstiloTarjeta}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="textoSeleccion" Text="{loc:Loc pag.muestras.sin_seleccion}" Foreground="{StaticResource ColorTextoSecundario}"/>
                    <TextBlock x:Name="textoSha" Text="" Foreground="{StaticResource ColorTextoTenue}" FontFamily="Cascadia Mono" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="botonGuardarMeta" Content="{loc:Loc pag.muestras.guardar}" Style="{StaticResource BotonPrimario}" Margin="0,0,8,0" Click="Guardar_Click" IsEnabled="False"/>
                    <Button x:Name="botonAnalizar" Content="Analizar" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="AnalizarSel_Click" IsEnabled="False"/>
                    <Button x:Name="botonExportarMeta" Content="{loc:Loc pag.muestras.exportar}" Style="{StaticResource BotonSecundario}" Margin="0,0,8,0" Click="ExportarSel_Click" IsEnabled="False"/>
                    <Button x:Name="botonEliminar" Content="{loc:Loc pag.muestras.eliminar}" Style="{StaticResource BotonPeligro}" Click="Eliminar_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
